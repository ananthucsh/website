<FilesMatch "\.(html|htm|js|css)$">
    FileETag None
    <IfModule mod_headers.c>
         Header unset ETag
         Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
         Header set Pragma "no-cache"
         Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
    </IfModule>
</FilesMatch>


# Enable rewrite engine
RewriteEngine On

# =========================
# ✅ OPTIONAL: WHITELIST YOUR IP
# Replace with your real IP (so you don’t get blocked)
# =========================
RewriteCond %{REMOTE_ADDR} !^123\.123\.123\.123$

# =========================
# 🌍 ALLOW ONLY INDIA (IN)
# =========================
RewriteCond %{ENV:GEOIP_COUNTRY_CODE} !^IN$
RewriteRule ^ - [F,L]

# =========================
# ❌ CUSTOM ERROR PAGE (403)
# =========================
ErrorDocument 403 "Access allowed only from India."

# =========================
# 🔒 BASIC SECURITY (OPTIONAL)
# =========================

# Disable directory browsing
Options -Indexes

# Protect .htaccess file
<Files .htaccess>
    Order Allow,Deny
    Deny from all
</Files>

# Block access to sensitive files
<FilesMatch "(^\.|config\.php|composer\.json|package\.json)">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# =========================
# ⚡ PERFORMANCE (OPTIONAL)
# =========================

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>
